{
  "input": "gang.mp4",
  "num_clips": 5,
  "min_duration": 10,
  "output_dir": "./output/showcase",
  "captions": true,
  "transcription_provider": "local",
  "whisper_mode": "python",
  "whisper_model": "base",
  "subtitle_preset": "legendary",
  "subtitle_animation": "impact",
  "subtitles_mode": "auto",
  "crop": true,
  "crop_mode": "face",
  "motion": true,
  "llm_enable": true,
  "llm_provider": "heuristic",
  "llm_model": "heuristic",
  "csv_path": "./output/showcase/benchmark.json",
  "csv_format": "json",
  "export_bundle": true,
  "export_bundle_path": "./output/showcase/export_bundle.json",
  "proof_report": true,
  "proof_report_path": "./output/showcase/proof_report.md",
  "thumbnails": true,
  "thumbnails_dir": "./output/showcase/thumbnails",
  "thumbnail_style": "cinematic",
  "thumbnail_collage": true,
  "thumbnail_collage_path": "./output/showcase/thumbnails/collage.jpg"
}
