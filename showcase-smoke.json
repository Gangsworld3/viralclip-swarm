{
  "input": "output/clip_1.mp4",
  "num_clips": 1,
  "min_duration": 2,
  "output_dir": "./output/showcase-smoke",
  "captions": false,
  "crop": true,
  "crop_mode": "face",
  "motion": true,
  "llm_enable": true,
  "llm_provider": "huggingface",
  "llm_model": "moonshotai/Kimi-K2-Instruct-0905",
  "llm_api_key_env": "HF_TOKEN",
  "csv_path": "./output/showcase-smoke/benchmark.json",
  "csv_format": "json",
  "export_bundle": true,
  "export_bundle_path": "./output/showcase-smoke/export_bundle.json",
  "proof_report": true,
  "proof_report_path": "./output/showcase-smoke/proof_report.md",
  "thumbnails": true,
  "thumbnails_dir": "./output/showcase-smoke/thumbnails",
  "thumbnail_style": "cinematic",
  "thumbnail_collage": true,
  "thumbnail_collage_path": "./output/showcase-smoke/thumbnails/collage.jpg"
}
